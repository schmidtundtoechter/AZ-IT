<?xml version="1.0" encoding="utf-8" ?>
<Crm Country="DE" Name="ERPNext" Version="1" SupportsEmojis="false">
  <Number Prefix="AsIs" MaxLength="15"/>
  <Connection MaxConcurrentRequests="2"/>
  <Parameters>
    <Parameter Name="ERPNextURL"        Type="String"  Editor="String"  Title="ERPNext Base URL:"     Default="https://erp.yourcompany.de"/>
    <Parameter Name="APIToken"          Type="String"  Editor="String"  Title="API Token (key:secret):"/>
    <Parameter Name="ReportCallEnabled" Type="Boolean" Editor="Boolean" Title="Enable Call Journaling" Default="false"/>
  </Parameters>
  <Authentication Type="No"/>
  <Scenarios>
    <Scenario Id="" Type="REST">
      <Request
        Url="[ERPNextURL]/api/method/az_it.az_it.api.telephony.lookup_contact_by_number?number=[Number]"
        MessagePasses="0"
        RequestType="Get"
        ResponseType="Json">
        <Headers>
          <Value Key="Authorization" Passes="0" Type="String">token [APIToken]</Value>
        </Headers>
      </Request>
      <Rules>
        <Rule Type="Any">message.contact_id</Rule>
      </Rules>
      <Variables>
        <Variable Name="ContactID"     Path="message.contact_id">    <Filter/></Variable>
        <Variable Name="FirstName"     Path="message.first_name">    <Filter/></Variable>
        <Variable Name="CompanyName"   Path="message.company_name">  <Filter/></Variable>
        <Variable Name="Email"         Path="message.email">         <Filter/></Variable>
        <Variable Name="PhoneBusiness" Path="message.phone_business"><Filter/></Variable>
        <Variable Name="PhoneMobile"   Path="message.phone_mobile">  <Filter/></Variable>
        <Variable Name="EntityType"    Path="message.entity_type">   <Filter/></Variable>
      </Variables>
      <Outputs AllowEmpty="false">
        <Output Type="ContactID"    Passes="0" Value="[ContactID]"/>
        <Output Type="FirstName"    Passes="0" Value="[FirstName]"/>
        <Output Type="CompanyName"  Passes="0" Value="[CompanyName]"/>
        <Output Type="Email"        Passes="0" Value="[Email]"/>
        <Output Type="PhoneBusiness" Passes="0" Value="[PhoneBusiness]"/>
        <Output Type="PhoneMobile"  Passes="0" Value="[PhoneMobile]"/>
        <Output Type="ContactUrl"   Passes="0" Value="[ERPNextURL]/[EntityType]/[ContactID]"/>
        <Output Type="EntityId"     Passes="0" Value="[ContactID]"/>
        <Output Type="EntityType"   Passes="0" Value="[EntityType]"/>
      </Outputs>
    </Scenario>
    <Scenario Id="ReportCall" Type="REST">
      <Request
        SkipIf="[IIf([ReportCallEnabled]!=True||[EntityId]==&quot;&quot;,True,[IIf([CallType]!=Inbound,True,False)])]"
        Url="[ERPNextURL]/api/method/az_it.az_it.api.telephony.log_call"
        MessagePasses="0"
        RequestType="Post"
        ResponseType="Json"
        RequestContentType="application/json">
        <Headers>
          <Value Key="Authorization" Passes="0" Type="String">token [APIToken]</Value>
        </Headers>
        <PostValues Key="">
          <Value Key="entity_id"        Passes="1" Type="String">[EntityId]</Value>
          <Value Key="entity_type"      Passes="1" Type="String">[EntityType]</Value>
          <Value Key="call_type"        Passes="1" Type="String">Inbound</Value>
          <Value Key="call_direction"   Passes="1" Type="String">[CallDirection]</Value>
          <Value Key="duration_seconds" Passes="1" Type="String">[DurationSeconds]</Value>
          <Value Key="agent_email"      Passes="1" Type="String">[AgentEmail]</Value>
          <Value Key="number"           Passes="1" Type="String">[Number]</Value>
        </PostValues>
      </Request>
      <Variables/>
      <Outputs Next="ReportCallMissed" AllowEmpty="true"/>
    </Scenario>
    <Scenario Id="ReportCallMissed" Type="REST">
      <Request
        SkipIf="[IIf([ReportCallEnabled]!=True||[EntityId]==&quot;&quot;,True,[IIf([CallType]!=Missed,True,False)])]"
        Url="[ERPNextURL]/api/method/az_it.az_it.api.telephony.log_call"
        MessagePasses="0"
        RequestType="Post"
        ResponseType="Json"
        RequestContentType="application/json">
        <Headers>
          <Value Key="Authorization" Passes="0" Type="String">token [APIToken]</Value>
        </Headers>
        <PostValues Key="">
          <Value Key="entity_id"        Passes="1" Type="String">[EntityId]</Value>
          <Value Key="entity_type"      Passes="1" Type="String">[EntityType]</Value>
          <Value Key="call_type"        Passes="1" Type="String">Missed</Value>
          <Value Key="call_direction"   Passes="1" Type="String">[CallDirection]</Value>
          <Value Key="duration_seconds" Passes="1" Type="String">0</Value>
          <Value Key="agent_email"      Passes="1" Type="String">[AgentEmail]</Value>
          <Value Key="number"           Passes="1" Type="String">[Number]</Value>
        </PostValues>
      </Request>
      <Variables/>
      <Outputs Next="ReportCallOutbound" AllowEmpty="true"/>
    </Scenario>
    <Scenario Id="ReportCallOutbound" Type="REST">
      <Request
        SkipIf="[IIf([ReportCallEnabled]!=True||[EntityId]==&quot;&quot;,True,[IIf([CallType]!=Outbound,True,False)])]"
        Url="[ERPNextURL]/api/method/az_it.az_it.api.telephony.log_call"
        MessagePasses="0"
        RequestType="Post"
        ResponseType="Json"
        RequestContentType="application/json">
        <Headers>
          <Value Key="Authorization" Passes="0" Type="String">token [APIToken]</Value>
        </Headers>
        <PostValues Key="">
          <Value Key="entity_id"        Passes="1" Type="String">[EntityId]</Value>
          <Value Key="entity_type"      Passes="1" Type="String">[EntityType]</Value>
          <Value Key="call_type"        Passes="1" Type="String">Outbound</Value>
          <Value Key="call_direction"   Passes="1" Type="String">[CallDirection]</Value>
          <Value Key="duration_seconds" Passes="1" Type="String">[DurationSeconds]</Value>
          <Value Key="agent_email"      Passes="1" Type="String">[AgentEmail]</Value>
          <Value Key="number"           Passes="1" Type="String">[Number]</Value>
        </PostValues>
      </Request>
      <Variables/>
      <Outputs Next="ReportCallNotAnswered" AllowEmpty="true"/>
    </Scenario>
    <Scenario Id="ReportCallNotAnswered" Type="REST">
      <Request
        SkipIf="[IIf([ReportCallEnabled]!=True||[EntityId]==&quot;&quot;,True,[IIf([CallType]!=Notanswered,True,False)])]"
        Url="[ERPNextURL]/api/method/az_it.az_it.api.telephony.log_call"
        MessagePasses="0"
        RequestType="Post"
        ResponseType="Json"
        RequestContentType="application/json">
        <Headers>
          <Value Key="Authorization" Passes="0" Type="String">token [APIToken]</Value>
        </Headers>
        <PostValues Key="">
          <Value Key="entity_id"        Passes="1" Type="String">[EntityId]</Value>
          <Value Key="entity_type"      Passes="1" Type="String">[EntityType]</Value>
          <Value Key="call_type"        Passes="1" Type="String">Notanswered</Value>
          <Value Key="call_direction"   Passes="1" Type="String">[CallDirection]</Value>
          <Value Key="duration_seconds" Passes="1" Type="String">0</Value>
          <Value Key="agent_email"      Passes="1" Type="String">[AgentEmail]</Value>
          <Value Key="number"           Passes="1" Type="String">[Number]</Value>
        </PostValues>
      </Request>
      <Variables/>
      <Outputs AllowEmpty="false"/>
    </Scenario>
  </Scenarios>
</Crm>
